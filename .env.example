# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Gmail credentials for OTP system
GMAIL_USER=muslimsathiteam@gmail.com
GMAIL_APP_PASSWORD=your_new_app_password_here

# Firebase Admin credentials (Required for OTP system)
# Get these from Firebase Console -> Project Settings -> Service Accounts
# After entering these, click 'Apply' to enable the OTP system.
# 1. GMAIL_USER: muslimsathiteam@gmail.com
# 2. GMAIL_APP_PASSWORD: (Create a new App Password for muslimsathiteam@gmail.com)
# 3. FIREBASE_ADMIN_PROJECT_ID: gen-lang-client-0377603990
# 4. FIREBASE_ADMIN_CLIENT_EMAIL: firebase-adminsdk-fbsvc@gen-lang-client-0377603990.iam.gserviceaccount.com
# 5. FIREBASE_ADMIN_PRIVATE_KEY: (Copy the full key from the JSON you provided)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Backend API URL (For Android/Capacitor Builds)
# e.g., https://my-app-backend.onrender.com
VITE_API_URL=https://muslim-sathi-video.onrender.com

# Firebase Messaging VAPID Key
# Get this from Firebase Console -> Project Settings -> Cloud Messaging -> Web Push certificates
VITE_FIREBASE_VAPID_KEY=

# Telegram Bot config for Video Uploads
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WEBHOOK_URL=https://your-ais-app-url.run.app
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=
